{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@pobcodes/shared-types": ["packages/shared-types/src/index.ts"],
      "@pobcodes/pob-codec": ["packages/pob-codec/src/index.ts"],
      "@pobcodes/pob-parser": ["packages/pob-parser/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist",
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  }
}

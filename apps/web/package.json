    "react-dom": "19.1.1",
    "wasmoon": "^1.16.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "jsdom": "^28.1.0",
    "wrangler": "^4.79.0"
  }
